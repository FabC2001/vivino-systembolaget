{
  "name": "Vivino rating for Systembolaget",
  "version": "2.0.0",
  "description": "Show vivino score on systembolaget wine pages",
  "manifest_version": 3,
  "permissions": ["storage", "unlimitedStorage"],
  "host_permissions": [
    "*://www.vivino.com/*",
    "*://www.systembolaget.se/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.systembolaget.se/*"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "bgScript.js"
  }
}
